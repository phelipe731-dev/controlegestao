{
  "name": "projeto-ph-ks",
  "private": true,
  "version": "1.0.0",
  "description": "MVP SaaS para gestao interna de campanha politica",
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build:backend": "npm --prefix backend run build",
    "build:frontend": "npm --prefix frontend run build",
    "prisma:generate": "npm --prefix backend run prisma:generate",
    "prisma:migrate": "npm --prefix backend run prisma:migrate",
    "seed": "npm --prefix backend run prisma:seed"
  }
}
